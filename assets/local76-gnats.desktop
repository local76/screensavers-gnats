[Desktop Entry]
Type=Application
Name=Gnats
Comment=Screensaver effect: gnats
Exec=env XCURSOR_PATH=/nonexistent XCURSOR_THEME=none xterm -fullscreen -bg black -fg white -ms black -xrm "XTerm*pointerColorBackground: black" -xrm "XTerm*pointerMode: 2" -e /usr/libexec/local76/screensavers/gnats
Icon=local76-gnats
Terminal=false
Categories=Screensaver;
